__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
dist/
build/
*.egg
.env

# NPC state (runtime-generated, per-user)
data/worlds/*/npc_state/

# Story Director runtime state (tick counter, recent decisions)
data/story_director/state.json
data/story_director/fact_ledger.json
data/story_director/fact_ledger.embeddings.npy
data/story_director/arcs.json
data/story_director/_tmp_*.json
data/story_director/_tmp_*.npy

# Per-world Story Director runtime state (mirrors the legacy paths above
# for any world that ships its own data/worlds/<world>/story/ pack)
data/worlds/*/story/state.json
data/worlds/*/story/fact_ledger.json
data/worlds/*/story/fact_ledger.embeddings.npy
data/worlds/*/story/arcs.json
data/worlds/*/story/_tmp_*.json
data/worlds/*/story/_tmp_*.npy

# Synthetic worlds for scaling tests — fully regeneratable from
# generate_synthetic_world.py with a fixed seed, no need to track
# 500+ procedural profile YAMLs in git history.
data/worlds/synthetic_*/

# Story Director bench outputs
tick_trace_*.json
data/worlds/*/player_quests.yaml.bak

# Models (too large for git)
models/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
